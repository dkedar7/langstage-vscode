{
  "name": "langstage-vscode",
  "displayName": "LangStage",
  "description": "Chat with your LangGraph agent from VS Code, alongside Copilot — the VS Code stage of the LangStage family.",
  "version": "0.3.1",
  "publisher": "dkedar7",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": ["AI", "Chat", "Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "chatParticipants": [
      {
        "id": "langstage.agent",
        "name": "langstage",
        "fullName": "LangStage",
        "description": "Run your LangGraph agent",
        "isSticky": true
      }
    ],
    "configuration": {
      "title": "LangStage",
      "properties": {
        "langstage.agentSpec": {
          "type": "string",
          "default": "",
          "description": "Agent spec 'path/to/agent.py:graph' or 'module:graph' to run. Leave empty to fall back to LANGSTAGE_AGENT_SPEC or the project's langstage.toml. (Legacy deepagent.agentSpec is still read as a fallback.)"
        },
        "langstage.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Python interpreter used to launch the langstage-vscode sidecar (must have langstage-vscode installed)."
        },
        "deepagent.agentSpec": {
          "type": "string",
          "default": "",
          "description": "DEPRECATED — use langstage.agentSpec.",
          "deprecationMessage": "Renamed to langstage.agentSpec."
        },
        "deepagent.pythonPath": {
          "type": "string",
          "default": "",
          "description": "DEPRECATED — use langstage.pythonPath.",
          "deprecationMessage": "Renamed to langstage.pythonPath."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.95.0",
    "typescript": "^5.4.0"
  }
}
